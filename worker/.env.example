# Copy to .env and fill in values. Never commit .env.

# Supabase
SUPABASE_URL=https://ctldinopklfbcqlwggqh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=

# Server
PORT=3000
NODE_ENV=development

# Pipeline pool — number of reports processed in parallel.
# CLAUDE.md targets 8–12 in-flight for the demo flood effect.
WORKER_CONCURRENCY=8
# Max rows the 5s poll fallback fetches per tick (catch-up after a missed Realtime event).
WORKER_POLL_BATCH=20
