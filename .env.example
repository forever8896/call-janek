# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys.
#
# Two sets of variables:
#   - EXPO_PUBLIC_*  → bundled into the mobile client (safe for public exposure)
#   - everything else → server-side only (the Bun/Hono worker), never bundled

# ──────────────────────────────────────────────────────────────────────
# Mobile client (Expo)
# Get from: Supabase Dashboard → Settings → API
# ──────────────────────────────────────────────────────────────────────

# Project URL, e.g. https://abcdefghij.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# anon / public key — safe to ship in the app bundle
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Bun/Hono worker base URL. Production: the Railway service URL
# (e.g. https://call-janek-worker-production.up.railway.app).
# Local dev: http://<your-LAN-ip>:3000 so a phone on the same Wi-Fi
# can reach `bun run dev` on your laptop.
EXPO_PUBLIC_API_URL=

# ──────────────────────────────────────────────────────────────────────
# Pipeline worker (Bun/Hono) — NEVER prefix with EXPO_PUBLIC_
# Lives in the worker's own .env, not the Expo .env.local
# ──────────────────────────────────────────────────────────────────────

# Same URL as above
SUPABASE_URL=

# service_role key — bypasses RLS, server-only, treat like a password
SUPABASE_SERVICE_ROLE_KEY=

# LLM + Whisper provider. OpenAI used for both transcription (Whisper) and
# the spam/dedupe/categorize/urgency/extraction steps. Swap or add others
# (Anthropic, local) as the pipeline evolves.
OPENAI_API_KEY=

# Web-search step (pick one and wire it; can defer until that step is built)
# TAVILY_API_KEY=
# SERPAPI_KEY=
# BRAVE_SEARCH_API_KEY=
